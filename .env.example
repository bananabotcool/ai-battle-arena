# AI Battle Arena - Environment Configuration

# Server Configuration
PORT=3001
NODE_ENV=production

# OpenClaw Gateway (for God AI narrator)
# Get your token from OpenClaw dashboard
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your_token_here

# Optional: Database (future feature)
# DATABASE_URL=mongodb://localhost:27017/ai-battle-arena

# Optional: Redis (future feature for caching)
# REDIS_URL=redis://localhost:6379

# Optional: Monitoring
# SENTRY_DSN=your_sentry_dsn_here

# Optional: Rate Limiting
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
